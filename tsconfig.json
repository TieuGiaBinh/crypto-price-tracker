{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "noImplicitAny": true,
    "strictNullChecks": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "outDir": "dist",

    "rootDir": "src"
  },

  "include": [
    "src"
  ]
}